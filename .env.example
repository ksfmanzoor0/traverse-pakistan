# ─────────────────────────────────────────────────────────────────
# Traverse Pakistan — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────────

# ── Site (required in production) ────────────────────────────────
# Canonical origin for absolute URLs in sitemap, canonical tags, and JSON-LD.
# Leave unset locally to use the default `https://traversepakistan.com`.
NEXT_PUBLIC_SITE_URL=https://traversepakistan.com


# ── Supabase (required for bookings + auth) ──────────────────────
# 1) Create a project at https://supabase.com
# 2) Copy both values from Project Settings → API
# 3) Paste them here (or into Vercel env vars for prod)
#
# Without these, auth + booking flows fall back to WhatsApp links.
# The public site still works for browsing/SEO.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...YOUR_ANON_KEY
# Service role key — server-side only, never expose to the browser.
# Required for write operations (bookings, payment status updates).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...YOUR_SERVICE_ROLE_KEY


# ── Revalidation secret (required for ISR cache purge endpoints) ─
# Must match the x-revalidate-secret header sent by your CMS/webhook.
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=


# ── Search Console / Bing Webmaster (optional) ───────────────────
# Paste the verification token from Google Search Console
# (Settings → Ownership verification → HTML tag → content value)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=


# ── Analytics (optional, not wired up yet) ───────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_VERCEL_ANALYTICS=true
